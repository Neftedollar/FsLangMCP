<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>FsLangMcp</PackageId>
    <Version>0.1.0</Version>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>fslangmcp</ToolCommandName>
    <PackageOutputPath>./nupkg</PackageOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="BoundedCache.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FSharp.Compiler.Service" Version="43.12.201" />
    <PackageReference Include="FsMcp.Server" Version="1.0.1" />
    <PackageReference Include="FsMcp.TaskApi" Version="1.0.1" />
    <PackageReference Include="Ionide.ProjInfo.FCS" Version="0.74.2" />
    <PackageReference Include="StreamJsonRpc" Version="2.24.84" />
  </ItemGroup>

</Project>
